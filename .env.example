# Runtime local / sidecar
OMNIPUBLISHER_HOST=127.0.0.1
OMNIPUBLISHER_PORT=7813
# Por padrão, em dev, os dados continuam na raiz do projeto.
# Em app empacotado, o Electron deve apontar para uma pasta gravável do usuário.
# OMNIPUBLISHER_DATA_DIR=C:/Users/seu_usuario/AppData/Roaming/SeuApp/omnipublisher
# OMNIPUBLISHER_DB_PATH=C:/Users/seu_usuario/AppData/Roaming/SeuApp/omnipublisher/omnipublisher.db
# OMNIPUBLISHER_SESSIONS_DIR=C:/Users/seu_usuario/AppData/Roaming/SeuApp/omnipublisher/sessions

# Configurações do YouTube
# O arquivo client_secret.json deve ser baixado do Google Cloud Console e colocado na raiz do projeto.
YOUTUBE_CLIENT_SECRETS_FILE=client_secret.json
YOUTUBE_OAUTH_PORT=8080

# Configurações do Instagram
INSTAGRAM_USERNAME=seu_usuario_do_instagram
INSTAGRAM_PASSWORD=sua_senha_do_instagram

# Tempo limite para as tarefas em background (opcional)
TIMEOUT_SECONDS=300
